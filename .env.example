# ── Guide Nusa — Zeabur Production ─────────────────────────────
# Isi nilai-nilai ini di Zeabur Dashboard → Variables

APP_NAME="Guide Nusa"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://guide-nusa.zeabur.app

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ── Database (isi dari MySQL Service Zeabur) ──────────────────
DB_CONNECTION=mysql
DB_HOST=<MYSQLHOST>
DB_PORT=3306
DB_DATABASE=<MYSQLDATABASE>
DB_USERNAME=<MYSQLUSER>
DB_PASSWORD=<MYSQLPASSWORD>

# ── Session ────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

# ── Cache ──────────────────────────────────────────────────────
CACHE_STORE=database

# ── Queue ──────────────────────────────────────────────────────
QUEUE_CONNECTION=database

# ── Mail ───────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Lainnya ────────────────────────────────────────────────────
FILESYSTEM_DISK=local

VITE_APP_NAME="${APP_NAME}"
